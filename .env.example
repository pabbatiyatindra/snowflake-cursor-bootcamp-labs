# Snowflake Bootcamp Labs - Environment Variables
#
# Copy this file to .env.local and fill in your Snowflake credentials
# WARNING: Never commit .env.local to git - contains passwords!
#

# Snowflake Account Identifier
# Format: xyz12345.us-east-1 (no https:// or .snowflakecomputing.com)
# Get from: Snowflake console URL or Snowflake admin
SNOWFLAKE_ACCOUNT=xyz12345.us-east-1

# Your Snowflake username
SNOWFLAKE_USER=your_bootcamp_username

# Your Snowflake password
# IMPORTANT: Never commit this file with real password
SNOWFLAKE_PASSWORD=your_secure_password

# Bootcamp database
# Created during setup (see docs/snowflake-setup.md)
SNOWFLAKE_DATABASE=bootcamp_db

# Training schema for labs
# All labs run in this schema
SNOWFLAKE_SCHEMA=training

# Compute warehouse for query execution
# Size: SMALL (1 credit/hr) for development, MEDIUM (2 credits/hr) for larger jobs
SNOWFLAKE_WAREHOUSE=compute_wh

# Custom role with bootcamp student privileges
# Created by instructor with least-privilege access
SNOWFLAKE_ROLE=bootcamp_student_role

# Optional: GitHub token for pushing solutions (advanced)
# Leave empty if not needed for bootcamp
GH_TOKEN=

# Optional: Cursor API key (if using Cursor standalone)
# Usually configured in Cursor settings, not needed here
CURSOR_API_KEY=
